  "name": "ErrorLog",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "errorCode": {
      "type": "string"
    },
    "errorMessage": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "timestamp"
  ]
}