{
  "name": "AppConfig",
  "type": "object",
  "properties": {
    "defaultPrompt": {
      "type": "string",
      "description": "Default transformation prompt applied to new sessions"
    },
    "autoEnhance": {
      "type": "boolean",
      "default": true
    },
    "maxConcurrentSessions": {
      "type": "number",
      "default": 10000
    }
  }
}